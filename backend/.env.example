# ========================================
# CurrículoJá Backend Configuration
# ========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# 
# Database is automatically initialized on startup
# NO Prisma - Using pg (node-postgres) driver
# ========================================

# ========================================
# DATABASE - PostgreSQL (pg driver)
# ========================================
# Option 1: Full connection string (Railway, Render, Heroku)
# DATABASE_URL=postgresql://user:password@localhost:5432/curriculoja

# Option 2: Individual connection parameters (local development) - PRIMARY
DB_HOST=localhost
DB_PORT=5432
DB_NAME=curriculoja
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# Option 3: Railway environment variables (PG* format)
# PGHOST=your-railway-host.railway.app
# PGPORT=5432
# PGDATABASE=curriculoja
# PGUSER=postgres
# PGPASSWORD=your_railway_password

# ========================================
# SERVER
# ========================================
PORT=3001
NODE_ENV=development

# ========================================
# JWT Secret (CHANGE THIS IN PRODUCTION!)
# ========================================
JWT_SECRET=sua_chave_jwt_super_secreta_aqui_2024
JWT_EXPIRES_IN=7d

# ========================================
# CORS Origins (URLs permitidas do frontend)
# ========================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
# Production: ALLOWED_ORIGINS=https://yourdomain.com

# ========================================
# Frontend URL (for Railway/Vercel deployment)
# ========================================
# FRONTEND_URL=http://localhost:5173
# FRONTEND_URL=https://your-frontend.vercel.app

# ========================================
# FILE UPLOADS
# ========================================
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# ========================================
# RATE LIMITING (optional)
# ========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# EMAIL NOTIFICATIONS (Nodemailer + LGPD)
# ========================================
# Email Service Provider
EMAIL_SERVICE=gmail
# Other options: outlook, yahoo, sendgrid, etc.

# Email Account (Gmail with App Password)
# Instructions: https://myaccount.google.com/apppasswords
EMAIL_USER=seu-email@gmail.com
EMAIL_PASSWORD=sua-senha-app-google-aqui

# Or use SMTP directly:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASSWORD=sua-senha-app-google-aqui

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# ========================================
# NOTIFICATIONS & LGPD COMPLIANCE
# ========================================
# WhatsApp Provider (for future integration)
# Options: evolution, zapi, twilio, wpp-connect
WHATSAPP_PROVIDER=

# WhatsApp API Configuration (when provider is configured)
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE_ID=
WHATSAPP_API_URL=

# Enable notification logging
NOTIFICATION_LOG=true

# ========================================
# LOGGING
# ========================================
# LOG_LEVEL=info

# ========================================
# ARTIFICIAL INTELLIGENCE (AI FEATURES)
# ========================================
# Choose your AI provider: openai or gemini
AI_PROVIDER=openai

# OpenAI Configuration (https://platform.openai.com/api-keys)
# Get your API key from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google Gemini Configuration (https://makersuite.google.com/app/apikey)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ========================================
# PAYMENT GATEWAY (BLOCO 3)
# ========================================
# Choose your payment provider: stripe or asaas
PAYMENT_PROVIDER=stripe

# Stripe Configuration (https://dashboard.stripe.com/apikeys)
# Get your API keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Stripe Product IDs and Price IDs (created in Stripe Dashboard)
STRIPE_PRO_PRODUCT_ID=prod_your_pro_product_id
STRIPE_PRO_PRICE_ID=price_your_pro_price_id
STRIPE_PREMIUM_PRODUCT_ID=prod_your_premium_product_id
STRIPE_PREMIUM_PRICE_ID=price_your_premium_price_id

# Alternative: Asaas Configuration (https://dashboard.asaas.com)
# Get your API key from: https://dashboard.asaas.com/settings/profile
ASAAS_API_KEY=
ASAAS_WEBHOOK_SECRET=

# Payment Webhook Configuration
PAYMENT_WEBHOOK_URL=https://seu-dominio.com/api/payments/webhook
PRICING_REDIRECT_URL=https://seu-dominio.com/pricing

# ========================================
# ADDITIONAL NOTES
# ========================================
# 1. Database tables are created automatically on server start
# 2. Initial seed data is added if database is empty
# 3. No migrations needed - using raw SQL initialization
# 4. See DATABASE_SETUP.md for more information
# 5. For AI features, you need to set up an API key with OpenAI or Google Gemini
